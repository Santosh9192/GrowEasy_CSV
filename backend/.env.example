# Server Configuration
PORT=4000

# CORS — set to your frontend URL in production (e.g., https://your-app.vercel.app)
# Use '*' to allow all origins (development only)
CORS_ORIGIN=*

# Set to 'true' when deployed behind a reverse proxy (Vercel, Railway, Render, Nginx)
TRUST_PROXY=false

# Rate Limiting — 30 requests per 60 seconds window for the /api/import endpoint
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Google Gemini AI — get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# AI Model — use 'gemini-2.0-flash' for speed or 'gemini-1.5-pro' for complex reasoning
AI_MODEL=gemini-2.0-flash

# Batch Processing
BATCH_SIZE=20          # Number of rows sent per AI batch
MAX_CONCURRENCY=3      # Number of concurrent AI requests
MAX_RETRIES=3          # Retry attempts for failed AI batches
